APP_NAME=Laravue
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost:8080

APP_LOCALE=pt_BR
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file
# APP_MAINTENANCE_STORE=database

# PHP_CLI_SERVER_WORKERS=4

BCRYPT_ROUNDS=12

# Canal daily: um arquivo por dia (storage/logs/laravel-YYYY-MM-DD.log)
LOG_CHANNEL=daily
LOG_DAILY_DAYS=30
# Opcional se LOG_CHANNEL=stack: canais separados por vírgula
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

# Sem Docker (SQLite local):
# DB_CONNECTION=sqlite

# Com Docker (compose.dev.yaml):
DB_CONNECTION=pgsql
DB_HOST=postgres
DB_PORT=5432
DB_DATABASE=laravue
DB_USERNAME=laravel
DB_PASSWORD=secret

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=redis

CACHE_STORE=redis
# CACHE_PREFIX=

MEMCACHED_HOST=127.0.0.1

REDIS_CLIENT=phpredis
REDIS_HOST=redis
REDIS_PASSWORD=null
REDIS_PORT=6379

MAIL_MAILER=log
MAIL_SCHEME=null
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="${APP_NAME}"

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

VITE_APP_NAME="${APP_NAME}"
VITE_PORT=5173

# Docker Compose (compose.dev.yaml)
UID=1000
GID=1000
NGINX_PORT=8080
POSTGRES_PORT=5432
POSTGRES_DATABASE=laravue
POSTGRES_USERNAME=laravel
POSTGRES_PASSWORD=secret
XDEBUG_ENABLED=true
XDEBUG_HOST=host.docker.internal
XDEBUG_IDE_KEY=DOCKER

# owen-it/laravel-auditing
AUDITING_ENABLED=true
AUDIT_QUEUE_ENABLED=true
AUDIT_QUEUE_CONNECTION=redis
# true = auditar também em artisan/tinker (cuidado em seeds). Em testes o padrão já cobre APP_ENV=testing.
# AUDIT_CONSOLE=false
